site_info <- read_excel("raw/Relevés_CISE_Prairie.xlsx",
sheet = "Info_relevés",
col_names = TRUE)
list_sp <- read_excel("raw/Relevés_CISE_Prairie.xlsx",
sheet = "Liste_espèce",
col_names = TRUE)
#clean data ----
#:)
##Supprimer les deux dernière colonnes du premier tableau ----
prairie_sp_clean <- prairie_sp %>%
select(-c((ncol(prairie_sp) - 1):ncol(prairie_sp)))
## Remplacer les NA par des 0 ----
prairie_sp_clean <- prairie_sp_clean %>%
mutate(across(where(is.numeric), ~ replace_na(., 0)))
## Renommer les colonnes du second tableau ----
noms_propres <- c("Annees", "Parcelles", "Hauteur_max_(cm)", "Hauteur_moyenne_(cm)","%_sol_nu", "	Mode_de_gestion", "Humidité_1", "Humidité_2", "Humidité_3", "Taupe" )
site_info_clean <- site_info %>%
set_names(noms_propres)
View(site_info)
# filtre prairies
prairie_sp_ACP <- prairie_sp_clean %>% filter(Parcelles %in% c("Grand parcelle", "Gite", "Parcelle regeneree", "Mesnil st père", "Mesnil st père 2"))
# filtre colonnes vides
prairie_sp_ACP <- prairie_sp_ACP[, colSums(prairie_sp_ACP != 0) > 0]
# Réaliser l'ACP
res.pca <- PCA(prairie_sp_ACP[, grep("Achmil", names(prairie_sp_ACP)):grep("Lotped", names(prairie_sp_ACP))], scale.unit = TRUE, ncp = 5, graph = FALSE)
summary(res.pca)
nrow(res.pca$ind$coord)  # Nombre d'individus dans l'ACP
round(res.pca$eig[,1],2) #valeurs propres
round(res.pca$eig[,3],2) #variance cumulative (% d'explication)
res.pca$var$cor # corrélation variables-facteurs
fviz_contrib(res.pca, choice = "var", axes = 1)
fviz_contrib(res.pca, choice = "var", axes = 2)
fviz_contrib(res.pca, choice = "var", axes = 3)
View(prairie_sp_ACP)
#cercles de corrélation - variables actives
#colorer en fct du cos2 : qualité de représentation
ACP <- fviz_pca_ind(res.pca)
ACP
#cercles de corrélation - variables actives
#colorer en fct du cos2 : qualité de représentation
