ShedToxDataBase <- read.csv2("ShedTox_Database_15_04_26_MR.csv",
encoding = "UTF-8",
strip.white = TRUE)
colnames(ShedToxDataBase)[colnames(ShedToxDataBase) == "15N/14N"] <- "N15_N14"
colnames(ShedToxDataBase)[colnames(ShedToxDataBase) == "13C/12C"] <- "C13_C12"
