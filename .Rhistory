#import raw ----
prairie_sp <- read_excel("raw/Relevés_CISE_Prairie.xlsx",
sheet = "Relevés_espèce",
col_names = TRUE)
prairie_sp$Cirarv <- as.numeric(prairie_sp$Cirarv)
