#On regroupe les SVL et SVL estimee dans SVL pour s'en servir comme données de taille ()
ShedToxDataBase$SVL[is.na(ShedToxDataBase$SVL) & !is.na(ShedToxDataBase$SVL_Estimee)] <- ShedToxDataBase$SVL_Estimee[is.na(ShedToxDataBase$SVL) & !is.na(ShedToxDataBase$SVL_Estimee)]
ShedToxDataBase_ETM <- ShedToxDataBase %>%
filter(Utilisation_ETM == "Oui") # filtre la base pour n'avoir que les mues dont les ETM ont été mesuré
#LOQ + Conversion des valeurs en valeurs numériques
ShedToxDataBase_ETM <- ShedToxDataBase_ETM %>%
mutate(across(all_of(c("Hg", "As", "Cd", "Co", "Cr", "Cu", "Fe", "Mn", "Ni", "Pb", "Se", "V","Zn","Ag")),
~ ifelse (grepl("< ", .x),
as.numeric(gsub("< ", "", .x)) / 2,
{
val <- suppressWarnings(as.numeric(.x))
ifelse(is.na(val), .x, val)
})))
ShedToxDataBase_ETM <- ShedToxDataBase_ETM %>%
mutate(across(all_of(c("Hg", "As", "Cd", "Co", "Cr", "Cu", "Fe", "Mn", "Ni", "Pb", "Se", "V","Zn","Ag", "Latitude_D", "Longitude_D","SVL")),
~ as.numeric(gsub(",",".",as.character(.x)))))
ShedToxDataBase <- ShedToxDataBase %>%
mutate(across(all_of(c("Hg", "As", "Cd", "Co", "Cr", "Cu", "Fe", "Mn", "Ni", "Pb", "Se", "V","Zn","Ag", "Latitude_D", "Longitude_D","SVL")),
~ as.numeric(gsub(",",".",as.character(.x)))))
View(ShedToxDataBase_ETM)
